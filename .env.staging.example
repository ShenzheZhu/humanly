# Copy to .env.staging on the GCP VM and fill in real values before running staging deploy.

DOMAIN=staging.writehumanly.net
STAGING_HTTP_PORT=8080

POSTGRES_DB=humanly_staging
POSTGRES_USER=humanly_user
POSTGRES_PASSWORD=CHANGEME_strong_staging_db_password

NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://humanly_user:CHANGEME_strong_staging_db_password@postgres:5432/humanly_staging
REDIS_URL=redis://redis:6379
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

JWT_SECRET=CHANGEME_run_openssl_rand_hex_32_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

CORS_ORIGIN=http://your-vm-hostname-or-ip:8080
FRONTEND_USER_URL=http://your-vm-hostname-or-ip:8080

EMAIL_SERVICE=console
EMAIL_FROM=noreply@yourdomain.com
EMAIL_API_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

RATE_LIMIT_ENABLED=true
LOG_LEVEL=info

AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=
DEFAULT_AI_API_KEY=
DEFAULT_AI_MODEL=gpt-4o
DEFAULT_AI_BASE_URL=https://openrouter.ai/api/v1
AI_ENCRYPTION_KEY=CHANGEME_run_openssl_rand_hex_32_here

NEXT_PUBLIC_API_URL=http://your-vm-hostname-or-ip:8080/api/v1
NEXT_PUBLIC_WS_URL=http://your-vm-hostname-or-ip:8080
NEXT_PUBLIC_TRACKER_URL=http://your-vm-hostname-or-ip:8080/tracker/humanly-tracker.min.js
