# ============================================================
# Humanly Production Environment Variables
# Copy to .env and fill in real values before deploying.
# Usage: docker compose --env-file .env -f docker-compose.prod.yml up -d
# ============================================================

# ── Public domain ────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=humanly_prod
POSTGRES_USER=humanly_user
POSTGRES_PASSWORD=CHANGEME_strong_db_password

# ── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Use Docker service names — NOT localhost
DATABASE_URL=postgresql://humanly_user:CHANGEME_strong_db_password@postgres:5432/humanly_prod
REDIS_URL=redis://redis:6379

DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=CHANGEME_run_openssl_rand_hex_32_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS — must match the public URL(s) the frontends are served from
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Used to build certificate verification links (fix for hardcoded localhost:3002)
FRONTEND_USER_URL=https://yourdomain.com

# Email (set EMAIL_SERVICE=sendgrid or smtp for real emails)
EMAIL_SERVICE=console
EMAIL_FROM=noreply@yourdomain.com
EMAIL_API_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Rate limiting
RATE_LIMIT_ENABLED=true

# Logging
LOG_LEVEL=info

# AI (optional — set AI_PROVIDER=openai and add a Together AI key)
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=
DEFAULT_AI_API_KEY=
DEFAULT_AI_MODEL=Qwen/Qwen3.5-9B
DEFAULT_AI_BASE_URL=https://api.together.xyz/v1
# generate with: openssl rand -hex 32
AI_ENCRYPTION_KEY=CHANGEME_run_openssl_rand_hex_32_here

# ── Frontend build-time variables (baked into JS bundle at build time) ────────
# Set these BEFORE running: docker compose -f docker-compose.prod.yml build
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://yourdomain.com
NEXT_PUBLIC_TRACKER_URL=https://yourdomain.com/tracker/humanly-tracker.min.js

# Admin dashboard is served at /admin (set as basePath in next.config.js at build time)
NEXT_PUBLIC_BASE_PATH=/admin
