# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://humanly_user:humanly_password@postgres:5432/humanly_prod
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_SSL=false

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=your-secret-key-here-generate-a-strong-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS Configuration (comma-separated list of allowed origins)
# Add all your frontend domains here, including both production and development URLs
# Example: https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000,http://localhost:3002
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Email Configuration
EMAIL_SERVICE=console
EMAIL_API_KEY=
EMAIL_FROM=noreply@writehumanly.net
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Rate Limiting
RATE_LIMIT_ENABLED=true

# PDF Upload Storage
# Production: set to /app/uploads (Docker volume mount ./uploads:/app/uploads)
# Development: leave unset to use ./storage/papers relative to compiled output
UPLOAD_DIR=/app/uploads

# AWS Configuration (Production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Logging
LOG_LEVEL=info
