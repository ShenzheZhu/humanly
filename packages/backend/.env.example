# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://humanly_user:humanly_password@localhost:5432/humanly_dev
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_SSL=false

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=dev-secret-key-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Set in production so app.writehumanly.net and admin.writehumanly.net share auth cookies.
# Leave empty for localhost development.
AUTH_COOKIE_DOMAIN=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
FRONTEND_ADMIN_URL=http://localhost:3000
FRONTEND_USER_URL=http://localhost:3002
PUBLIC_API_URL=http://localhost:3001/api/v1

# Email Configuration
EMAIL_SERVICE=console
EMAIL_STRICT_DELIVERY=false
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_API_KEY=
EMAIL_FROM=noreply@humanly.dev
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# OAuth Login
# Callback URLs:
# - Google/GitHub local: http://localhost:3001/api/v1/auth/oauth/<provider>/callback
# - Google/GitHub production: https://app.writehumanly.net/api/v1/auth/oauth/<provider>/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Rate Limiting
RATE_LIMIT_ENABLED=true

# PDF Upload Storage
FILE_STORAGE_PROVIDER=local
UPLOAD_DIR=./storage

# Google Cloud Storage PDF Storage
# Set FILE_STORAGE_PROVIDER=gcs to store new uploaded PDFs in GCS.
GCS_BUCKET_NAME=
GCS_BUCKET_REGION=
GCS_PROJECT_ID=
GCS_KEY_FILENAME=
FILE_STORAGE_KEY_PREFIX=files
# GOOGLE_APPLICATION_CREDENTIALS can also be used by Google auth libraries.
# Production GCS example:
# FILE_STORAGE_PROVIDER=gcs
# GCS_BUCKET_NAME=humanly-prod-pdfs
# GCS_BUCKET_REGION=US
# GCS_PROJECT_ID=hai-gcp-representation

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AI runtime guardrails. Provider API keys are stored per user, not in backend env.
AI_AGENT_MAX_TOOL_CALLS=60
AI_PROVIDER_TIMEOUT_MS=180000
AI_ENCRYPTION_KEY=CHANGEME_run_openssl_rand_hex_32_here

# Logging
LOG_LEVEL=info
