# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://humory_user:humory_password@localhost:5432/humory_dev
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_SSL=false

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=dev-secret-key-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Email Configuration
EMAIL_SERVICE=console
EMAIL_API_KEY=
EMAIL_FROM=noreply@humory.dev
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Rate Limiting
RATE_LIMIT_ENABLED=true

# PDF Upload Storage
UPLOAD_DIR=./storage/papers

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AI Configuration
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=
DEFAULT_AI_API_KEY=
DEFAULT_AI_MODEL=Qwen/Qwen3.5-9B
DEFAULT_AI_BASE_URL=https://api.together.xyz/v1
AI_ENCRYPTION_KEY=CHANGEME_run_openssl_rand_hex_32_here

# Logging
LOG_LEVEL=info
