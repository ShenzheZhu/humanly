# Backend API URL
# For production: https://api.yourdomain.com/api/v1
# For local development: http://localhost:3001/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Public origins
# Leave blank locally to keep same-origin links. Production defaults are:
# NEXT_PUBLIC_MARKETING_ORIGIN=https://writehumanly.net
# NEXT_PUBLIC_PRODUCT_APP_ORIGIN=https://app.writehumanly.net
NEXT_PUBLIC_MARKETING_ORIGIN=
NEXT_PUBLIC_PRODUCT_APP_ORIGIN=
